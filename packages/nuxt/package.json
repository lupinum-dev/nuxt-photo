{
  "name": "@nuxt-photo/nuxt",
  "version": "0.0.1",
  "type": "module",
  "description": "Photo galleries, lightboxes, and provider-aware image rendering for Nuxt.",
  "keywords": [
    "nuxt-photo",
    "nuxt",
    "photos",
    "gallery",
    "lightbox"
  ],
  "homepage": "https://github.com/lupinum-dev/nuxt-photo",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lupinum-dev/nuxt-photo.git",
    "directory": "packages/nuxt"
  },
  "bugs": {
    "url": "https://github.com/lupinum-dev/nuxt-photo/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "import": "./dist/module.mjs",
      "types": "./dist/module.d.mts"
    }
  },
  "main": "./dist/module.mjs",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "nuxt-module-build build",
    "dev": "nuxt-module-build build --stub"
  },
  "dependencies": {
    "@nuxt-photo/core": "workspace:*",
    "@nuxt-photo/recipes": "workspace:*",
    "@nuxt-photo/vue": "workspace:*",
    "@nuxt/kit": "^4.4.2",
    "@nuxt/schema": "^4.4.2"
  },
  "peerDependencies": {
    "@nuxt/image": "^2.0.0",
    "nuxt": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "@nuxt/image": {
      "optional": true
    }
  },
  "devDependencies": {
    "@nuxt/module-builder": "^1.0.2",
    "nuxt": "^4.4.2",
    "typescript": "5.9.3"
  }
}
