{
  "name": "@nuxt-photo/core",
  "version": "0.1.0",
  "type": "module",
  "description": "Framework-free layout, image, gesture, and photo-model logic for Nuxt Photo.",
  "keywords": [
    "nuxt-photo",
    "photos",
    "gallery",
    "lightbox",
    "layout"
  ],
  "homepage": "https://github.com/lupinum-dev/nuxt-photo",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lupinum-dev/nuxt-photo.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/lupinum-dev/nuxt-photo/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "unbuild",
    "dev": "unbuild --stub"
  },
  "devDependencies": {
    "typescript": "6.0.3",
    "unbuild": "^3.5.0"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20.19.0 || >=22.12.0"
  }
}
