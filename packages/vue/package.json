{
  "name": "@nuxt-photo/vue",
  "version": "0.0.1",
  "type": "module",
  "description": "Vue composables and primitives for Nuxt Photo.",
  "keywords": [
    "nuxt-photo",
    "vue",
    "photos",
    "gallery",
    "lightbox"
  ],
  "homepage": "https://github.com/lupinum-dev/nuxt-photo",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lupinum-dev/nuxt-photo.git",
    "directory": "packages/vue"
  },
  "bugs": {
    "url": "https://github.com/lupinum-dev/nuxt-photo/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.ts"
    },
    "./extend": {
      "import": "./dist/extend.mjs",
      "types": "./dist/extend.d.ts"
    }
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "unbuild",
    "dev": "unbuild --stub"
  },
  "dependencies": {
    "@nuxt-photo/core": "workspace:*",
    "embla-carousel-vue": "9.0.0-rc01"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "embla-carousel": "9.0.0-rc01",
    "typescript": "5.9.3",
    "unbuild": "^3.5.0",
    "vue": "3.5.31",
    "vue-tsc": "2.2.12"
  }
}
