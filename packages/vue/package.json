{
  "name": "@nuxt-photo/vue",
  "version": "0.1.0",
  "type": "module",
  "description": "Vue composables and primitives for Nuxt Photo.",
  "keywords": [
    "nuxt-photo",
    "vue",
    "photos",
    "gallery",
    "lightbox"
  ],
  "homepage": "https://github.com/lupinum-dev/nuxt-photo",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lupinum-dev/nuxt-photo.git",
    "directory": "packages/vue"
  },
  "bugs": {
    "url": "https://github.com/lupinum-dev/nuxt-photo/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "unbuild",
    "dev": "unbuild --stub"
  },
  "dependencies": {
    "@nuxt-photo/core": "workspace:*",
    "@nuxt-photo/engine": "workspace:*",
    "embla-carousel-vue": "9.0.0-rc02"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "embla-carousel": "9.0.0-rc02",
    "typescript": "6.0.3",
    "unbuild": "^3.5.0",
    "vue": "3.5.33",
    "vue-tsc": "3.2.7"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20.19.0 || >=22.12.0"
  }
}
